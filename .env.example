# Servidor
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:4000
DATABASE_PATH=./data/nexus.db
# Em producao use o Neon/Postgres. Quando DATABASE_URL existe, o Nexus ignora o SQLite.
DATABASE_URL=

# Imagens no Cloudinary. Se ficar vazio, o Nexus salva imagens localmente.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=nexus

# Midia no Cloudflare R2. Quando completo, o Nexus usa R2 antes do Cloudinary.
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=nexus-media

# Opcional: importacao automatica local do Gerador de Contas Roblox.
# Nao envie este arquivo com contas reais para o GitHub.
ROBLOX_ACCOUNTS_FILE=./data/roblox-accounts.txt

# RushMail (Temp Email). Crie a chave em https://rushmail.dev/dashboard.
# Cada chamada bem-sucedida, exceto GET /me, consome 1 credito.
RUSHMAIL_API_KEY=
RUSHMAIL_API_URL=https://rushmail.dev/public-api

# Discord OAuth2
DISCORD_CLIENT_ID=seu_client_id
DISCORD_CLIENT_SECRET=seu_client_secret
DISCORD_REDIRECT_URI=http://localhost:4000/api/auth/discord/callback
# Use "implicit" para login local sem Client Secret, ou "code" para producao com Client Secret.
DISCORD_OAUTH_FLOW=implicit
# Opcional para a aba Discord Tools e para preencher nome/avatar ao criar uma licenca.
# Tambem publica o comando /conta do bot de vendas. Configure no Render e nunca no GitHub.
DISCORD_BOT_TOKEN=
DISCORD_DEFAULT_GUILD_ID=
# Ative tambem no Discord Developer Portal antes de usar true.
DISCORD_MESSAGE_CONTENT_INTENT=false
DISCORD_GUILD_MEMBERS_INTENT=false

# Segredos
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_MASTER_KEY=base64_com_32_bytes
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=segredo_longo_para_sessoes

# Whitelist inicial. O primeiro ID vira owner se nenhum papel for informado.
# Formato: discordId[:owner|admin|member],discordId[:owner|admin|member]
AUTHORIZED_DISCORD_IDS=123456789012345678:owner,987654321098765432:member

# Seguranca de producao
REQUIRE_HTTPS=false
# No Render use true para o Express reconhecer HTTPS e o IP encaminhado pelo proxy.
TRUST_PROXY=false
